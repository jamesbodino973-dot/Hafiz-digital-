{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A digital product asset inside the Hafiz store",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Product title"
        },
        "description": {
          "type": "string",
          "description": "A short summary description of the product"
        },
        "fullDescription": {
          "type": "string",
          "description": "Double line description or list of features"
        },
        "price": {
          "type": "number",
          "description": "One-time digital asset premium selling price"
        },
        "category": {
          "type": "string",
          "description": "Asset category, e.g. Template, Preset, Icon Pack, eBook, Software"
        },
        "image": {
          "type": "string",
          "description": "Image URL or base64 data uri"
        },
        "downloadLink": {
          "type": "string",
          "description": "Google Drive folder or Mediafire download reference"
        },
        "fileSize": {
          "type": "string",
          "description": "Optional metadata file size indicator"
        },
        "fileType": {
          "type": "string",
          "description": "Optional metadata file type extension"
        },
        "createdAt": {
          "type": "object",
          "description": "Firestore server timestamp metadata"
        }
      },
      "required": [
        "title",
        "description",
        "fullDescription",
        "price",
        "category",
        "image",
        "downloadLink"
      ]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "A digital asset purchase made by an authenticated user",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Auth UID of the customer"
        },
        "userEmail": {
          "type": "string",
          "description": "Email address of the customer"
        },
        "productId": {
          "type": "string",
          "description": "The purchased product identifier"
        },
        "productTitle": {
          "type": "string",
          "description": "Product title"
        },
        "productImage": {
          "type": "string",
          "description": "Product category image cover"
        },
        "productCategory": {
          "type": "string",
          "description": "Category of the product"
        },
        "downloadLink": {
          "type": "string",
          "description": "High speed download path"
        },
        "pricePaid": {
          "type": "number",
          "description": "Price charged"
        },
        "purchasedAt": {
          "type": "object",
          "description": "The transaction timestamp"
        }
      },
      "required": [
        "userId",
        "userEmail",
        "productId",
        "productTitle",
        "productImage",
        "productCategory",
        "downloadLink",
        "pricePaid",
        "purchasedAt"
      ]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Live digital product catalog dataset"
    },
    "/purchases/{purchaseId}": {
      "schema": "Purchase",
      "description": "Purchased items history to enable lifetime access"
    }
  }
}
